# ═════════════════════════════════════════════════════════════
# vigia-24h · variáveis de ambiente
# ═════════════════════════════════════════════════════════════
# Setup:
#   cp .env.example .env
#   edita o .env com seus valores
# Atenção: NÃO commite o .env (já está no .gitignore)
# Sem aspas nos valores. Sem espaço em volta do `=`.
# ═════════════════════════════════════════════════════════════


# ── Meta Marketing API ───────────────────────────────────────

# META_ACCESS_TOKEN
# Token long-lived com `ads_read` E `ads_management` (precisa dos dois,
# porque o vigia pode pausar conjunto / ajustar orçamento via comando)
# Pega em: developers.facebook.com → Marketing API → Token Tool
# Formato: começa com `EAA`. Sem "Bearer ", sem aspas.
META_ACCESS_TOKEN=

# META_AD_ACCOUNT_ID
# ID da conta (com prefixo `act_`)
# Exemplo: META_AD_ACCOUNT_ID=act_1234567890
META_AD_ACCOUNT_ID=act_


# ── Obsidian Vault ───────────────────────────────────────────

# OBSIDIAN_VAULT_PATH
# Caminho absoluto. SEM `/` no final. Sem `~`. Sem aspas.
# Exemplo: /Users/voce/Documents/obsidian-bravo
OBSIDIAN_VAULT_PATH=/Users/voce/Documents/obsidian-bravo


# ── Evo Go (Evolution Go) ────────────────────────────────────
# Pra alertar no WhatsApp + receber confirmação ("responde ok").

# EVO_API_URL
# URL completa, COM `https://`, SEM `/` no final.
# Exemplo: https://api.suavps.com.br
EVO_API_URL=https://api.suavps.com.br

# EVO_API_KEY
# apikey da instância (UUID gerado pela Evo Go)
# Sem aspas, sem "Bearer ", sem espaço.
# Exemplo: EVO_API_KEY=a539340d-4a9c-4378-8e74-28d48ff94a9f
EVO_API_KEY=

# EVO_INSTANCE_NAME (opcional, só pra log + endpoint v2)
# Slug sem espaço. Se setado, o script tenta fallback /message/sendText/<instance>
# (Evolution API v2) caso /send/text/ (Evo Go) falhe.
EVO_INSTANCE_NAME=growthtap


# ── Configuração do Vigia ────────────────────────────────────

# VIGIA_INTERVAL_MIN
# Frequência do loop em MINUTOS (não segundos).
# Número inteiro, sem aspas. Default 15.
# Recomendado: 5 (intenso), 15 (default), 30 (econômico)
# Cuidado: Meta API tem rate limit — abaixo de 5 pode dar problema
VIGIA_INTERVAL_MIN=15

# VIGIA_ALERT_NUMBER
# Número (formato internacional sem `+`, só dígitos) que recebe os alertas no WhatsApp.
# Exemplo: VIGIA_ALERT_NUMBER=5511999998888
# Pode ser sobrescrito via flag --to no CLI.
VIGIA_ALERT_NUMBER=
